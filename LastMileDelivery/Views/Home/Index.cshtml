@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";

}

<section class="py-5">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h6 class="text-warning fw-bold text-uppercase font-heading mb-2">
                Our Services
            </h6>
            <h2 class="display-5 font-heading fw-bold text-dark">
                Comprehensive Shipping Solutions
            </h2>
            <p class="text-muted mx-auto" style="max-width: 600px">
                Tailored logistics services to meet every business need.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="card service-card border-0 shadow h-100 rounded-4">
                    <div class="position-relative overflow-hidden rounded-top-4"
                         style="height: 200px">
                        <img src="assets/fast-img.png"
                             class="w-100 h-100 object-fit-cover"
                             alt="Express Delivery" />
                    </div>
                    <div class="card-body p-4">
                        <h4 class="font-heading fw-bold mb-2">Express Delivery</h4>
                        <p class="text-muted">
                            Same-day and next-day delivery options for urgent shipments.
                            We prioritize speed without compromising safety.
                        </p>
                        <a href="#"
                           class="btn btn-link text-warning fw-bold p-0 text-decoration-none">
                            Learn More <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="card service-card border-0 shadow h-100 rounded-4">
                    <div class="position-relative overflow-hidden rounded-top-4"
                         style="height: 200px">
                        <img src="/assets/vision.png"
                             class="w-100 h-100 object-fit-cover"
                             alt="International Shipping" />
                    </div>
                    <div class="card-body p-4">
                        <h4 class="font-heading fw-bold mb-2">Global Shipping</h4>
                        <p class="text-muted">
                            Seamless international logistics with customs clearance
                            handling. Connect your business to the world.
                        </p>
                        <a href="#"
                           class="btn btn-link text-warning fw-bold p-0 text-decoration-none">
                            Learn More <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="card service-card border-0 shadow h-100 rounded-4">
                    <div class="position-relative overflow-hidden rounded-top-4"
                         style="height: 200px">
                        <img src="assets/warehouse-img.png"
                             class="w-100 h-100 object-fit-cover"
                             alt="Smart Warehousing" />
                    </div>
                    <div class="card-body p-4">
                        <h4 class="font-heading fw-bold mb-2">Smart Warehousing</h4>
                        <p class="text-muted">
                            State-of-the-art storage facilities with AI-driven inventory
                            management and automated fulfillment.
                        </p>
                        <a href="#"
                           class="btn btn-link text-warning fw-bold p-0 text-decoration-none">
                            Learn More <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5 bg-light">
    <div class="container py-5">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <img src="assets/deliveryimg.png"
                     class="img-fluid rounded-4 shadow-lg"
                     alt="Delivery Features" />
            </div>
            <div class="col-lg-6">
                <h6 class="text-warning fw-bold text-uppercase font-heading mb-2">
                    Why Choose Us
                </h6>
                <h2 class="display-5 font-heading fw-bold mb-4 text-dark">
                    Smart Logistics for Modern Businesses
                </h2>
                <p class="text-muted mb-4">
                    We leverage cutting-edge technology to ensure your deliveries are
                    faster, safer, and more transparent than ever before.
                </p>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0 bg-white p-3 rounded shadow-sm text-warning">
                        <i class="bi bi-geo-alt fs-3"></i>
                    </div>
                    <div class="ms-3">
                        <h5 class="fw-bold">Real-Time Tracking</h5>
                        <p class="text-muted mb-0">
                            Watch your shipment move on a live map from pickup to
                            doorstep.
                        </p>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0 bg-white p-3 rounded shadow-sm text-warning">
                        <i class="bi bi-shield-check fs-3"></i>
                    </div>
                    <div class="ms-3">
                        <h5 class="fw-bold">Secure Handling</h5>
                        <p class="text-muted mb-0">
                            Digital proof of delivery with photo and signature
                            verification.
                        </p>
                    </div>
                </div>

                <div class="d-flex">
                    <div class="flex-shrink-0 bg-white p-3 rounded shadow-sm text-warning">
                        <i class="bi bi-speedometer2 fs-3"></i>
                    </div>
                    <div class="ms-3">
                        <h5 class="fw-bold">Fastest Delivery</h5>
                        <p class="text-muted mb-0">
                            AI-optimized routes ensure we beat the traffic and the clock.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

