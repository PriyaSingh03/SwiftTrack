@{
    ViewData["Title"] = "Features";
    Layout = "_Master";
}




<section class="features" id="features">
    <div class="container">

        <div class="section-header">
            <h2>Powerful Features</h2>
            <p>
                Everything you need to manage your delivery operations efficiently
            </p>
        </div>

        <div class="features-grid">

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fa-solid fa-location-dot"></i>
                </div>
                <h3>Real-Time Tracking</h3>
                <p>
                    Track all deliveries in real-time with GPS integration and live
                    status updates.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fa-solid fa-route"></i>
                </div>
                <h3>Route Optimization</h3>
                <p>
                    AI-powered route planning considering traffic and weather
                    conditions.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fa-solid fa-bell"></i>
                </div>
                <h3>Distance Calculation</h3>
                <p>
                    Calculate distance from warehouse to customer door-step.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fa-solid fa-camera"></i>
                </div>
                <h3>Proof of Delivery</h3>
                <p>
                    Capture photos and digital signatures as delivery confirmation.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                </div>
                <h3>Billing & Payments</h3>
                <p>
                    Automated invoice generation and secure payment processing.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fa-solid fa-chart-line"></i>
                </div>
                <h3>Analytics Dashboard</h3>
                <p>
                    Comprehensive reports and insights to optimize operations.
                </p>
            </div>

        </div>
    </div>
</section>
