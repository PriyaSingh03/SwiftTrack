@{
    ViewData["Title"] = "Our Team";
    Layout = "_Master";
}

<style>
    .team-section {
        background-color: #1a1a1a;
        color: #FFFFFF;
        padding: 80px 0;
        min-height: 100vh;
        width: 100%;
    }

    .team-header-title {
        font-size: 4rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -2px;
        line-height: 0.9;
        margin-bottom: 70px;
    }

    .team-card {
        background-color: #e0ddd5;
        border-radius: 12px;
        padding: 20px;
        color: #1a1a1a;
        transition: all 0.3s ease;
        border: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        /* Matches the aspect ratio in your reference image */
        min-height: 380px;
    }

        .team-card:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

    .team-img-wrapper {
        width: 100%;
        background: #ccc;
        margin-bottom: 15px;
        border-radius: 6px;
        overflow: hidden;
    }

        .team-img-wrapper img {
            width: 100%;
            height: 280px;
            object-fit: cover;
            display: block;
        }

    .member-name {
        font-weight: 800;
        font-size: 1.5rem;
        margin-top: 15px;
        margin-bottom: 0;
    }

    .brand-footer {
        margin-top: 80px;
        font-weight: 700;
        letter-spacing: 5px;
        opacity: 0.7;
    }
</style>

<section class="team-section">
    <div class="container-fluid px-lg-5 text-center">

        <h1 class="team-header-title">
            INTRODUCTION OF<br>OUR TEAM
        </h1>

        <div class="row g-5 justify-content-center">

            <div class="col-sm-6 col-lg-4">
                <div class="team-card shadow-lg">
                    <div class="team-img-wrapper">
                        <img src="~/assets/Image (10).jpg" alt="Priya Singh">
                    </div>
                    <h5 class="member-name">Priya Singh</h5>
                </div>
            </div>

            <div class="col-sm-6 col-lg-4">
                <div class="team-card shadow-lg">
                    <div class="team-img-wrapper">
                        <img src="~/assets/Image (8).jpg" alt="Kavipriya M">
                    </div>
                    <h5 class="member-name">Kavipriya M</h5>
                </div>
            </div>

            <div class="col-sm-6 col-lg-4">
                <div class="team-card shadow-lg">
                    <div class="team-img-wrapper">
                        <img src="~/assets/Image.jpg" alt="Varshini L">
                    </div>
                    <h5 class="member-name">Varshini L</h5>
                </div>
            </div>

            <div class="col-sm-6 col-lg-4">
                <div class="team-card shadow-lg">
                    <div class="team-img-wrapper">
                        <img src="~/assets/vedheep.jpg" alt="Vedheep Dasari">
                    </div>
                    <h5 class="member-name">Vedheep Dasari</h5>
                </div>
            </div>

            <div class="col-sm-6 col-lg-4">
                <div class="team-card shadow-lg">
                    <div class="team-img-wrapper">
                        <img src="~/assets/ifran.jpg" alt="Ifran">
                    </div>
                    <h5 class="member-name">Ifran</h5>
                </div>
            </div>

        </div>

        <div class="brand-footer text-uppercase">
            SwiftTrack
        </div>
    </div>
</section>