@model LastMileDelivery.Models.Delivery
@{
    Layout = "~/Views/Shared/_Agent.cshtml";
}

<div class="card" style="max-width: 500px; margin: 40px auto; text-align: center; border-top: 5px solid #dc3545;">
    <div class="card-body p-5">
        <div class="mb-4">
            @* Changed icon to times-circle and color to red for cancellation *@
            <i class="fas fa-times-circle" style="font-size: 4rem; color: #dc3545;"></i>
        </div>
        <h2 class="fw-bold">Order Cancelled</h2>
        <p class="text-muted">
            The order <strong>#DEL-@Model.DeliveryId</strong> has been cancelled by the administrator or customer.
            No further actions can be taken on this delivery.
        </p>
        <a asp-action="Dashboard" class="btn btn-secondary mt-3 w-100">
            Back to Dashboard
        </a>
    </div>
</div>