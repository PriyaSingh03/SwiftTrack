@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Login.cshtml";
}

<div class="login-page">
    <div class="login-left">
        <div class="login-left-content">
            <h1>Welcome Back!</h1>
            <p>Track your deliveries, manage routes, and stay connected.</p>
            <img src="https://cdn-icons-png.flaticon.com/512/2769/2769339.png" alt="Delivery" />
        </div>
    </div>

    <div class="login-right">
        <div class="login-form-container">
            <a asp-controller="Home" asp-action="Index" class="logo" style="margin-bottom: 32px; display: inline-flex; text-decoration: none; align-items: center; gap: 10px;">
                <div class="logo-icon">
                    <i class="fas fa-truck-fast"></i>
                </div>
                <span style="font-size: 1.5rem; font-weight: bold; color: #333;">SwiftTrack</span>
            </a>

            <h2>Sign In</h2>
            <p style="color: #666; margin-bottom: 2rem;">Enter your credentials to access your account</p>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger text-center small">
                    @TempData["Error"]
                </div>
            }

            <form asp-controller="Auth" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group" style="margin-bottom: 1rem;">
                    <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Email Address</label>
                    <input type="email" name="Email" class="form-control" placeholder="name@example.com" required
                           style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;" />
                </div>

                <div class="form-group" style="margin-bottom: 1rem;">
                    <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Password</label>
                    <input type="password" name="Password" class="form-control" placeholder="Enter your password" required
                           style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px;" />
                </div>

                <div class="form-group" style="margin-bottom: 2rem;">
                    <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Login As</label>
                    <select name="role" class="form-control" style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 4px; background-color: white;">
                        <option value="ADMIN">Admin</option>
                        <option value="DELIVERY_AGENT">Delivery Agent</option>
                        <option value="CUSTOMER">Customer</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary login-btn">
                    Sign In <i class="fas fa-arrow-right"></i>
                </button>
            </form>

            <div class="login-divider" style="text-align: center; margin: 1.5rem 0; color: #999;">or</div>

            <p class="signup-link" style="text-align: center;">
                Don't have an account?
                <a asp-controller="Auth" asp-action="Register">Sign Up</a>
            </p>
        </div>
    </div>
</div>