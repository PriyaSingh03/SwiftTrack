<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SwiftTrack</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />    
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

</head>


<body>
    <div class="dashboard">

        <!-- Sidebar -->
        <aside class="sidebar admin-dashboard">
            <div class="sidebar-header">
                <div class="logo-icon"><i class="fa-solid fa-truck"></i></div>
                <span class="font-heading fw-bold fs-4 text-white">SwiftTrack</span>
            </div>
           

            <nav class="sidebar-nav">
                <a asp-controller="Admin" asp-action="AdminDashboard">
                    <i class="fas fa-th-large"></i> Dashboard
                </a>
                <a asp-controller="Admin" asp-action="AdminDeliveries">
                    <i class="fas fa-box"></i> Deliveries
                </a>
                <a asp-controller="Admin" asp-action="AdminAgents">
                    <i class="fas fa-users"></i> Agents
                </a>
                <a asp-controller="Admin" asp-action="AdminCustomer">
                    <i class="fas fa-user-friends"></i> Customers
                </a>
                <a asp-controller="Admin" asp-action="AdminBilling">
                    <i class="fas fa-file-invoice-dollar"></i> Billings
                </a>
                
            </nav>

            <div class="sidebar-footer">
                <a asp-controller="Auth" asp-action="Logout">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </aside>

        <!-- Page Content -->
        <main class="main-content">
            @RenderBody()
        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>